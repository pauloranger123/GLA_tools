<Window x:Class="GLAtools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GLA Tools" Height="780" Width="1100"
        Icon="Assets/app_icon.ico"
        MinHeight="500" MinWidth="700"
        WindowState="Maximized"
        Background="{StaticResource BrushBgDarkest}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== CABECALHO ===================== -->
        <Border Grid.Row="0" Background="{StaticResource BrushWoodMid}" Padding="20,16"
                BorderBrush="{StaticResource BrushGoldBorder}" BorderThickness="0,0,0,2">
            <TextBlock Text="⚓ ALLIANCE MANAGER" Style="{StaticResource TextTitle}" VerticalAlignment="Center"/>
        </Border>

        <!-- ===================== ABAS ===================== -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                    Style="{StaticResource WoodTabControl}">

            <!-- ABA 1: GERENCIAMENTO DE ALIANCA -->
            <TabItem Header="Gerenciamento de Aliança" Style="{StaticResource WoodTabItem}">
                <Grid x:Name="AllianceTabRoot">

                    <!-- TELA DE SETUP INICIAL (so aparece se ainda nao configurou a alianca) -->
                    <Border x:Name="SetupPanel" Background="{StaticResource BrushWoodTexture}"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
                            <TextBlock Text="Configurar Aliança" Style="{StaticResource TextTitle}"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <TextBlock Text="Quantos membros tem a sua aliança atualmente?"
                                       Style="{StaticResource TextBody}" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBox x:Name="PlayerCountInput" Style="{StaticResource WoodTextBox}"
                                     Width="120" HorizontalAlignment="Center" Margin="0,0,0,16"
                                     HorizontalContentAlignment="Center"/>
                            <Button Content="Criar Aliança" Style="{StaticResource WoodButton}"
                                    HorizontalAlignment="Center" Click="CreateAlliance_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- AREA PRINCIPAL (gerenciamento de metas) -->
                    <Grid x:Name="MainContentPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Barra de acoes -->
                        <Border Grid.Row="0" Padding="20,14" Background="#2B1810">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="+ Nova Meta" Style="{StaticResource WoodButton}"
                                        Click="NewGoal_Click" Margin="0,0,10,0"/>
                                <Button Content="Gerenciar Membros" Style="{StaticResource WoodButtonSecondary}"
                                        Click="ManageMembers_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Grade de cards + estado vazio, sobrepostos no mesmo Grid.Row -->
                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <ItemsControl x:Name="GoalsItemsControl"
                                              ItemTemplate="{StaticResource GoalCardTemplate}"
                                              HorizontalAlignment="Stretch">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>

                            <TextBlock x:Name="EmptyStateText"
                                       Text="Nenhuma meta criada ainda. Clique em &quot;+ Nova Meta&quot; para começar."
                                       Style="{StaticResource TextMuted}" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ABA 2: CALCULADORA DE CRAFT (placeholder por enquanto) -->
            <TabItem Header="Calculadora de Craft" Style="{StaticResource WoodTabItem}">
                <Grid>
                    <TextBlock Text="Em breve: calculadora de materiais de craft."
                               Style="{StaticResource TextMuted}" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>

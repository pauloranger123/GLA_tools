<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <!-- ===================== PALETA DE CORES ===================== -->
            <!-- Baseada na interface do jogo: madeira escura, dourado envelhecido, vermelho de destaque -->
            <Color x:Key="ColorBgDarkest">#1A0F0A</Color>
            <Color x:Key="ColorWoodMid">#5C3A28</Color>
            <Color x:Key="ColorWoodLight">#7A5236</Color>
            <Color x:Key="ColorGoldText">#E8C589</Color>
            <Color x:Key="ColorGoldBorder">#C9A876</Color>
            <Color x:Key="ColorAccentRed">#8B2635</Color>
            <Color x:Key="ColorAccentRedHover">#A6324354</Color>
            <Color x:Key="ColorSuccessGreen">#6BA54A</Color>
            <Color x:Key="ColorTextMuted">#B8967A</Color>

            <SolidColorBrush x:Key="BrushBgDarkest" Color="{StaticResource ColorBgDarkest}"/>
            <SolidColorBrush x:Key="BrushWoodMid" Color="{StaticResource ColorWoodMid}"/>
            <SolidColorBrush x:Key="BrushWoodLight" Color="{StaticResource ColorWoodLight}"/>
            <SolidColorBrush x:Key="BrushGoldText" Color="{StaticResource ColorGoldText}"/>
            <SolidColorBrush x:Key="BrushGoldBorder" Color="{StaticResource ColorGoldBorder}"/>
            <SolidColorBrush x:Key="BrushAccentRed" Color="{StaticResource ColorAccentRed}"/>
            <SolidColorBrush x:Key="BrushSuccessGreen" Color="{StaticResource ColorSuccessGreen}"/>
            <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}"/>

            <!-- Opacity baixo (0.18) faz a textura aparecer bem de leve, quase
                 como um "ruido" de fundo, em vez de competir visualmente com o
                 conteudo do card (textos, inputs). -->
            <ImageBrush x:Key="BrushWoodTexture"
                        ImageSource="pack://application:,,,/Assets/wood_texture.png"
                        TileMode="Tile"
                        Viewport="0,0,400,400"
                        ViewportUnits="Absolute"
                        Opacity="0.18"/>

            <!-- ===================== TIPOGRAFIA ===================== -->
            <Style x:Key="TextTitle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushGoldText}"/>
                <Setter Property="FontSize" Value="22"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="Georgia"/>
            </Style>

            <Style x:Key="TextBody" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushGoldText}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>

            <Style x:Key="TextMuted" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
            </Style>

            <!-- ===================== BOTAO ESTILO MADEIRA ===================== -->
            <Style x:Key="WoodButton" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource BrushAccentRed}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="BorderBrush" Value="{StaticResource BrushGoldBorder}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    x:Name="border">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Botao secundario (mais discreto, tom de madeira em vez de vermelho) -->
            <Style x:Key="WoodButtonSecondary" TargetType="Button" BasedOn="{StaticResource WoodButton}">
                <Setter Property="Background" Value="{StaticResource BrushWoodMid}"/>
            </Style>

            <!-- ===================== CAIXA DE TEXTO ===================== -->
            <Style x:Key="WoodTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="#2B1810"/>
                <Setter Property="Foreground" Value="{StaticResource BrushGoldText}"/>
                <Setter Property="CaretBrush" Value="{StaticResource BrushGoldText}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BrushGoldBorder}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding" Value="8,5"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===================== TABCONTROL ESTILO MADEIRA ===================== -->
            <!-- Replica o visual de abas do jogo: aba ativa em vermelho, inativas em madeira escura -->
            <Style x:Key="WoodTabItem" TargetType="TabItem">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="18,10"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="{StaticResource BrushWoodMid}"
                                    BorderBrush="{StaticResource BrushGoldBorder}"
                                    BorderThickness="1,1,1,0"
                                    CornerRadius="6,6,0,0"
                                    Margin="0,0,3,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   TextElement.Foreground="{StaticResource BrushGoldText}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource BrushAccentRed}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WoodTabControl" TargetType="TabControl">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid Background="{StaticResource BrushBgDarkest}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#2B1810" Padding="12,8,0,0">
                                    <TabPanel IsItemsHost="True" HorizontalAlignment="Left"/>
                                </Border>
                                <Border Grid.Row="1" Background="{StaticResource BrushBgDarkest}">
                                    <ContentPresenter ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===================== SCROLLBAR ESTILO MADEIRA ===================== -->
            <!-- Substitui a barra de rolagem branca padrao do Windows por uma fina,
                 escura, com o "thumb" (parte arrastavel) em dourado. Aplicada
                 globalmente a todo ScrollBar do app, dentro ou fora dos cards. -->
            <Style x:Key="WoodScrollBarThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{StaticResource BrushGoldBorder}"
                                    CornerRadius="3" Opacity="0.7"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WoodScrollBarLineButton" TargetType="RepeatButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WoodScrollBarPageButton" TargetType="RepeatButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="#2B1810"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="10"/>
                <Setter Property="MinWidth" Value="10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="#2B1810">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Track x:Name="PART_Track" IsDirectionReversed="True" Width="10">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand"
                                                      Style="{StaticResource WoodScrollBarPageButton}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource WoodScrollBarThumb}" Width="8"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand"
                                                      Style="{StaticResource WoodScrollBarPageButton}"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

</ResourceDictionary>
